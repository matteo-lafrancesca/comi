# Base de données SQLite locale
DATABASE_URL="file:./dev.db"

# Token Uploadthing pour le stockage des images
# Remplacez par votre token de projet Uploadthing
UPLOADTHING_TOKEN="votre_token_uploadthing_ici"

# Secret JWT pour signer les tokens (générez une chaîne aléatoire sécurisée)
JWT_SECRET="votre_secret_jwt_tres_long_et_securise_ici"

