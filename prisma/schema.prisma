datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           Int             @id @default(autoincrement())
  email        String          @unique
  passwordHash String          @map("password_hash")
  createdAt    DateTime        @default(now()) @map("created_at")
  repas        Repas[]
  programmation Programmation[]

  @@map("users")
}

model Repas {
  id            Int               @id @default(autoincrement())
  userId        Int               @map("user_id")
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  titre         String
  recette       String?
  photoUrl      String?           @map("photo_url")
  createdAt     DateTime          @default(now()) @map("created_at")
  ingredients   RepasIngredient[]
  programmation Programmation[]

  @@map("repas")
}

model Ingredient {
  id        Int               @id @default(autoincrement())
  nom       String            @unique
  categorie String            // e.g., "fruits-legumes", "epicerie-salee"
  repas     RepasIngredient[]

  @@map("ingredients")
}

model RepasIngredient {
  id           Int        @id @default(autoincrement())
  repasId      Int        @map("repas_id")
  repas        Repas      @relation(fields: [repasId], references: [id], onDelete: Cascade)
  ingredientId Int        @map("ingredient_id")
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  quantite     Float?
  unite        String?

  @@map("repas_ingredients")
}

model Programmation {
  id      Int      @id @default(autoincrement())
  userId  Int      @map("user_id")
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  repasId Int      @map("repas_id")
  repas   Repas    @relation(fields: [repasId], references: [id], onDelete: Cascade)
  date    DateTime
  heure   Int      // 0 = midi, 1 = soir

  @@map("programmation")
}
